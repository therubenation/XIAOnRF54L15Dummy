/* uart21 (xiao_serial) uses GPIO2 pins (FLPR domain) — pinctrl hangs on cpuapp-only build.
   Console stays on uart20 (default). UART debug not accessible via connector. */

/ {
    chosen {
        zephyr,console = &cdc_acm_uart0;
        zephyr,shell-uart = &cdc_acm_uart0;
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};
